{
  "name": "photolina",
  "version": "1.0.0",
  "description": "Photolina – Free Photoshop-like image editor",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build:installer": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.photolina.app",
    "productName": "Photolina",
    "directories": { "output": "dist" },
    "extraResources": [
      { "from": "../index.html", "to": "." },
      { "from": "../css", "to": "css" },
      { "from": "../js", "to": "js" },
      { "from": "../manifest.json", "to": "." }
    ],
    "win": {
      "target": ["portable", "nsis"]
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
